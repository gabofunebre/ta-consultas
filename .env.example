SECRET_KEY=poneme-una-clave-segura
DATABASE_URL=

# Variables de inicialización del contenedor postgres (solo se aplican al crear el clúster por primera vez)
POSTGRES_DB=consultas_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Variables de conexión usadas por la app (si se omiten, caen en POSTGRES_*).
DB_NAME=consultas_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

UPLOAD_FOLDER=/app/uploads
